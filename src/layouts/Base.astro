---
import "../styles/global.css";
import T from "../components/T.astro";

interface Props {
  title: string;
  description?: string;
  current?: "home" | "collections" | "about";
  // Set on post pages: switches og:type to "article" and emits BlogPosting.
  published?: Date;
}

const {
  title,
  description = "한상호(Sangho Han)의 기술 블로그. 백엔드·인프라·AI/LLM 서빙·보안 대응·엔지니어링 회고를 기록합니다.",
  current,
  published,
} = Astro.props;
const year = new Date().getFullYear();

// --- SEO/GEO ---
const SITE = "https://bbang.dev";
// Canonical: served URLs are directory-style (trailing slash); normalize so
// the tag always matches the live URL. new URL() percent-encodes Korean
// slugs, staying consistent with sitemap.xml.
const _p = Astro.url.pathname;
const canonical = new URL(_p.endsWith("/") ? _p : _p + "/", SITE).href;
const isArticle = !!published;
const headline = title.replace(/\s+—\s+bbang\.dev$/, "");

const person = {
  "@type": "Person",
  "@id": `${SITE}/#person`,
  name: "한상호 (Sangho Han)",
  url: `${SITE}/about/`,
  sameAs: [
    "https://github.com/bbbang105",
    "https://www.linkedin.com/in/sangho105/",
    "https://www.instagram.com/bbang_dev/",
    "https://x.com/bbang_dev",
  ],
};
const website = {
  "@type": "WebSite",
  "@id": `${SITE}/#website`,
  url: `${SITE}/`,
  name: "bbang.dev",
  inLanguage: "ko",
  publisher: { "@id": `${SITE}/#person` },
};
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    website,
    person,
    ...(isArticle
      ? [
          {
            "@type": "BlogPosting",
            headline,
            datePublished: published!.toISOString(),
            dateModified: published!.toISOString(),
            author: { "@id": `${SITE}/#person` },
            publisher: { "@id": `${SITE}/#person` },
            mainEntityOfPage: canonical,
            url: canonical,
            image: `${SITE}/og/default.png`,
            inLanguage: "ko",
          },
        ]
      : []),
  ],
};
---

<!doctype html>
<html lang="en" data-theme="light" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" />
    <meta property="og:image" content="https://bbang.dev/og/default.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://bbang.dev/og/default.png" />
    <link rel="preload" as="font" type="font/woff2"
      href="/fonts/SarasaMonoK-Regular.woff2" crossorigin />
    {/* No-flash theme: applied before paint */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          if (t !== "dark" && t !== "light") t = "light";
          document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    {/* No-flash language: applied before paint. Default = en. */}
    <script is:inline>
      (function () {
        // Global chrome (header/footer/nav) is always English.
        // Per-page language (currently only About) is scoped locally.
        try {
          document.documentElement.dataset.lang = "en";
          document.documentElement.lang = "en";
        } catch (e) {}
      })();
    </script>
    {/* SEO/GEO: canonical, OG core, Twitter text, RSS, JSON-LD.
        og:image / twitter:card / twitter:image are set above. */}
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="bbang.dev"
      href={`${SITE}/rss.xml`}
    />
    <meta property="og:type" content={isArticle ? "article" : "website"} />
    <meta property="og:site_name" content="bbang.dev" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {
      isArticle && (
        <meta
          property="article:published_time"
          content={published!.toISOString()}
        />
      )
    }
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {/* Google Analytics 4 — reused property from the legacy Quartz site. */}
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-BKNGY77L23"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-BKNGY77L23");
    </script>
  </head>
  <body>
    <header class="masthead">
      <div class="wrap">
        <div class="mast-bar">
          <a class="brand" href="/">
            <span class="mark">bbang<span class="blink">.</span>dev</span>
            <small>tech log</small>
          </a>
          <div class="mast-tools">
            <button
              class="theme-toggle ico"
              id="theme-toggle"
              type="button"
              aria-label="Toggle color theme">◐</button
            >
          </div>
        </div>
        <nav class="nav" aria-label="Primary">
          <a href="/" aria-current={current === "home" ? "page" : undefined}>
            <T en="Home" ko="홈" />
          </a>
          <a
            href="/collections"
            aria-current={current === "collections" ? "page" : undefined}
          >
            <T en="Collections" ko="컬렉션" />
          </a>
          <a
            href="/about"
            aria-current={current === "about" ? "page" : undefined}
          >
            <T en="About" ko="소개" />
          </a>
          <input
            id="q"
            class="hsearch"
            type="search"
            autocomplete="off"
            spellcheck="false"
            placeholder="Search — title, tag, description"
            aria-label="Search posts by title, tag, or description"
          />
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-foot">
      <div class="wrap">
        <span class="copy">
          <T
            en={`© ${year} bbang.dev · All rights reserved.`}
            ko={`© ${year} bbang.dev · All rights reserved.`}
          />
        </span>
        <nav class="foot-links" aria-label="Social">
          <a href="https://github.com/bbbang105" rel="me noopener"
            >GitHub</a
          >
          <a href="https://www.linkedin.com/in/sangho105/" rel="me noopener"
            >LinkedIn</a
          >
          <a href="https://www.instagram.com/bbang_dev/" rel="me noopener"
            >Instagram</a
          >
          <a href="https://x.com/bbang_dev" rel="me noopener">X</a>
          <a href="mailto:hchsa77@gmail.com">Email</a>
        </nav>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var btn = document.getElementById("theme-toggle");
        if (!btn) return;
        function sync() {
          var dark = document.documentElement.dataset.theme === "dark";
          btn.setAttribute("aria-pressed", dark ? "true" : "false");
          btn.setAttribute(
            "aria-label",
            dark ? "다크 모드 — 라이트로 전환" : "라이트 모드 — 다크로 전환",
          );
          btn.title = dark ? "다크 모드" : "라이트 모드";
        }
        btn.addEventListener("click", function () {
          var cur = document.documentElement.dataset.theme;
          var next = cur === "dark" ? "light" : "dark";
          document.documentElement.dataset.theme = next;
          try {
            localStorage.setItem("theme", next);
          } catch (e) {}
          sync();
        });
        sync();
      })();
    </script>
    <script is:inline>
      (function () {
        var q = document.getElementById("q");
        if (!q) return;
        // The home feed owns live search + pagination. Here we only handle
        // searching from another page: Enter jumps to home with ?q=.
        q.addEventListener("keydown", function (e) {
          if (e.key !== "Enter") return;
          if (!document.querySelector(".led-row"))
            location.href = "/?q=" + encodeURIComponent(q.value.trim());
        });
      })();
    </script>
  </body>
</html>
