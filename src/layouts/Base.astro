---
import "../styles/global.css";
import T from "../components/T.astro";

interface Props {
  title: string;
  description?: string;
  current?: "home" | "collections" | "about";
}

const { title, description = "한상호 — 기술 블로그 (Astro 프로토타입)", current } =
  Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en" data-theme="light" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preload" as="font" type="font/woff2"
      href="/fonts/SarasaMonoK-Regular.woff2" crossorigin />
    {/* No-flash theme: applied before paint */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          if (!t)
            t = window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    {/* No-flash language: applied before paint. Default = en. */}
    <script is:inline>
      (function () {
        try {
          var l = localStorage.getItem("lang");
          if (l !== "ko" && l !== "en") l = "en";
          document.documentElement.dataset.lang = l;
          document.documentElement.lang = l;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="masthead">
      <div class="wrap">
        <div class="mast-bar">
          <a class="brand" href="/">
            <span class="mark">bbang<span class="blink">.</span>dev</span>
            <small>tech log</small>
          </a>
          <div class="mast-tools">
            <button
              class="theme-toggle ico"
              id="lang-toggle"
              type="button"
              aria-label="Toggle language"
            >
              <span data-lang-en>KO</span><span data-lang-ko>EN</span>
            </button>
            <button
              class="theme-toggle ico"
              id="theme-toggle"
              type="button"
              aria-label="Toggle color theme">◐</button
            >
          </div>
        </div>
        <nav class="nav" aria-label="Primary">
          <a href="/" aria-current={current === "home" ? "page" : undefined}>
            <T en="Home" ko="홈" />
          </a>
          <a
            href="/collections"
            aria-current={current === "collections" ? "page" : undefined}
          >
            <T en="Collections" ko="컬렉션" />
          </a>
          <a
            href="/about"
            aria-current={current === "about" ? "page" : undefined}
          >
            <T en="About" ko="소개" />
          </a>
          <input
            id="q"
            class="hsearch"
            type="search"
            autocomplete="off"
            spellcheck="false"
            placeholder="Search — title, tag, description"
            aria-label="Search posts by title, tag, or description"
          />
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-foot">
      <div class="wrap">
        <span class="copy">
          <T
            en={`© ${year} Sangho Han — bbang.dev`}
            ko={`© ${year} 한상호 (Sangho Han) — bbang.dev`}
          />
        </span>
        <nav class="foot-links" aria-label="Social">
          <a href="https://github.com/bbbang105" rel="me noopener"
            >GitHub</a
          >
          <a href="https://www.linkedin.com/in/sangho105/" rel="me noopener"
            >LinkedIn</a
          >
          <a href="https://www.instagram.com/bbang_dev/" rel="me noopener"
            >Instagram</a
          >
          <a href="https://www.threads.com/@bbang_dev" rel="me noopener"
            >Threads</a
          >
          <a href="https://x.com/bbang_dev" rel="me noopener">X</a>
          <a href="mailto:hchsa77@gmail.com">Email</a>
        </nav>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var btn = document.getElementById("theme-toggle");
        if (!btn) return;
        btn.addEventListener("click", function () {
          var cur = document.documentElement.dataset.theme;
          var next = cur === "dark" ? "light" : "dark";
          document.documentElement.dataset.theme = next;
          try {
            localStorage.setItem("theme", next);
          } catch (e) {}
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var btn = document.getElementById("lang-toggle");
        if (!btn) return;
        btn.addEventListener("click", function () {
          var cur = document.documentElement.dataset.lang;
          var next = cur === "ko" ? "en" : "ko";
          document.documentElement.dataset.lang = next;
          document.documentElement.lang = next;
          try {
            localStorage.setItem("lang", next);
          } catch (e) {}
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var q = document.getElementById("q");
        if (!q) return;
        // The home feed owns live search + pagination. Here we only handle
        // searching from another page: Enter jumps to home with ?q=.
        q.addEventListener("keydown", function (e) {
          if (e.key !== "Enter") return;
          if (!document.querySelector(".led-row"))
            location.href = "/?q=" + encodeURIComponent(q.value.trim());
        });
      })();
    </script>
  </body>
</html>
